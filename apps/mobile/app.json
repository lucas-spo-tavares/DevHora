{
  "expo": {
    "name": "DevHora",
    "slug": "devhora",
    "version": "1.0.5",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "devhora",
    "icon": "./assets/icon.png",
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      "expo-notifications"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "versionCode": 15,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F8FBF4"
      },
      "package": "com.devhora.app"
    },
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FBFAF5"
    },
    "web": {
      "bundler": "metro"
    }
  }
}
