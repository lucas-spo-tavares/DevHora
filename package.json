{
  "name": "devhora",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "engines": {
    "node": ">=22 <23"
  },
  "packageManager": "npm@10.8.2",
  "overrides": {
    "expo": "51.0.39",
    "expo-modules-core": "1.12.26"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "mobile:start": "npm run start --workspace @devhora/mobile",
    "mobile:android": "npm run android --workspace @devhora/mobile",
    "mobile:ios": "npm run ios --workspace @devhora/mobile",
    "mobile:web": "npm run web --workspace @devhora/mobile",
    "mobile:build:apk": "npm run build:apk --workspace @devhora/mobile",
    "mobile:build:aab": "npm run build:aab --workspace @devhora/mobile",
    "mobile:build:local": "./scripts/build-mobile-release.sh aab",
    "landing:dev": "npm run dev --workspace @devhora/landing",
    "landing:build": "npm run build --workspace @devhora/landing",
    "landing:tf:init": "terraform -chdir=infra/terraform/landing init",
    "landing:tf:apply": "terraform -chdir=infra/terraform/landing apply",
    "landing:deploy": "node scripts/deploy-landing.mjs"
  },
  "devDependencies": {
    "turbo": "^2.5.0"
  }
}
